# ─────────────────────────────────────────────────────────────
# Scriptora — example environment variables (safe placeholders)
# Copy to .env.local for local dev:
#   cp .env.example .env.local
#
# RULES:
# - VITE_*  → exposed to the browser bundle (publishable keys only).
# - NEVER commit .env, .env.local, .env.production, or .env.vercel.
# - Vercel production: set vars in Project → Settings → Environment Variables.
# - Do NOT create .env.production locally — it overrides .env during vite build.
# - Server secrets (DEEPSEEK_API_KEY, etc.) → Supabase Edge Function secrets only.
# ─────────────────────────────────────────────────────────────

# ─── Supabase (REQUIRED for auth + backend) ────────────────
VITE_SUPABASE_PROJECT_ID="your-project-ref"
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"

# Legacy anon JWT (eyJ...) — required for AI / Edge Functions when using a publishable key
VITE_SUPABASE_ANON_KEY="your-legacy-anon-jwt"

# ─── App identity / build metadata (optional) ────────────────
VITE_APP_VERSION="1.0.0"
VITE_BUILD_CHANNEL="stable"

# ─── Feature flags (optional) ────────────────────────────────
VITE_AI_PROVIDER="deepseek"
VITE_ENABLE_GEMINI="false"

VITE_ENABLE_PAYMENTS="false"
VITE_PAYMENT_MODE="coming_soon"
VITE_PAYMENT_PROVIDER="none"
VITE_PAYMENT_MONTHLY_URL=""
VITE_PAYMENT_YEARLY_URL=""
VITE_PAYMENT_LIFETIME_URL=""
VITE_PAYMENT_SUCCESS_URL="/dashboard?payment=success"
VITE_PAYMENT_CANCEL_URL="/pricing?payment=cancelled"

VITE_ENABLE_DOWNLOADS="false"
VITE_DOWNLOAD_MODE="coming_soon"
VITE_ANDROID_APK_URL=""
VITE_ANDROID_AAB_URL=""
VITE_MAC_DMG_URL=""
VITE_MAC_ZIP_URL=""
VITE_WINDOWS_EXE_URL=""

# ─────────────────────────────────────────────────────────────
# SERVER-ONLY (supabase secrets set — never in frontend env):
#   DEEPSEEK_API_KEY, BRAVE_SEARCH_API_KEY, FAL_KEY, SUPABASE_SERVICE_ROLE_KEY
# ─────────────────────────────────────────────────────────────
